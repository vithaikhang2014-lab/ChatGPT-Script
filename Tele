--// KhazHub GUI

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

-- GUI
local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "KhazHub"

local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 220, 0, 160)
frame.Position = UDim2.new(0.4, 0, 0.3, 0)
frame.BorderSizePixel = 0
frame.Active = true
frame.BackgroundColor3 = Color3.fromRGB(255,0,0)

-- Rainbow effect 🌈
task.spawn(function()
    local hue = 0
    while true do
        frame.BackgroundColor3 = Color3.fromHSV(hue,1,1)
        hue = hue + 0.01
        if hue > 1 then hue = 0 end
        task.wait(0.03)
    end
end)

-- Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "KhazHub"
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(255,255,255)
title.Font = Enum.Font.GothamBold

-- Info label
local info = Instance.new("TextLabel", frame)
info.Position = UDim2.new(0,0,0,30)
info.Size = UDim2.new(1,0,0,20)
info.BackgroundTransparency = 1
info.Text = "Đã lưu: 0"
info.TextColor3 = Color3.fromRGB(255,255,255)
info.TextScaled = true

-- Notify label
local notify = Instance.new("TextLabel", screenGui)
notify.Size = UDim2.new(0,200,0,40)
notify.Position = UDim2.new(0.4,0,0.1,0)
notify.BackgroundColor3 = Color3.fromRGB(0,0,0)
notify.TextColor3 = Color3.fromRGB(255,255,255)
notify.Visible = false
notify.TextScaled = true

local function showNotify(text)
    notify.Text = text
    notify.Visible = true
    task.wait(2)
    notify.Visible = false
end

-- Buttons
local function createButton(text, y)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.9,0,0,25)
    btn.Position = UDim2.new(0.05,0,0,y)
    btn.Text = text
    btn.TextScaled = true
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    return btn
end

local saveBtn = createButton("Lưu vị trí", 55)
local tpBtn = createButton("Dịch chuyển", 85)
local resetBtn = createButton("RESET", 115)

-- Data
local positions = {}
local currentIndex = 1

-- Save position
saveBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        table.insert(positions, char.HumanoidRootPart.Position)
        info.Text = "Đã lưu: "..#positions
    end
end)

-- Teleport
tpBtn.MouseButton1Click:Connect(function()
    if #positions == 0 then
        showNotify("Vui lòng lưu vị trí!")
        return
    end

    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(positions[currentIndex])
        currentIndex = currentIndex + 1
        if currentIndex > #positions then
            currentIndex = 1
        end
    end
end)

-- Reset
resetBtn.MouseButton1Click:Connect(function()
    positions = {}
    currentIndex = 1
    info.Text = "Đã lưu: 0"
end)

-- Draggable + nút tròn trắng ⚪
local dragBtn = Instance.new("TextButton", frame)
dragBtn.Size = UDim2.new(0,20,0,20)
dragBtn.Position = UDim2.new(1,-22,0,2)
dragBtn.Text = "+"
dragBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
dragBtn.TextColor3 = Color3.fromRGB(0,0,0)

local dragging = false
local dragInput, mousePos, framePos

dragBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        mousePos = input.Position
        framePos = frame.Position
    end
end)

dragBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - mousePos
        frame.Position = UDim2.new(
            framePos.X.Scale,
            framePos.X.Offset + delta.X,
            framePos.Y.Scale,
            framePos.Y.Offset + delta.Y
        )
    end
end)
